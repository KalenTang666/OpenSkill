{
  "name": "openskill",
  "version": "1.2.0",
  "description": "CLI for managing cross-domain AI data assets (Skills, Memory, Preferences)",
  "keywords": [
    "ai",
    "skills",
    "agent",
    "cross-platform",
    "mcp",
    "claude",
    "codex",
    "openclaw",
    "openskill",
    "agent-skills"
  ],
  "author": "Kalen666",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/KalenTang666/OpenSkill.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/KalenTang666/OpenSkill",
  "type": "module",
  "bin": {
    "hw": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/cli.ts src/index.ts --format esm --dts --clean",
